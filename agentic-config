#!/usr/bin/env python3
"""
agentic - Setup and operate Agentic Config repositories.

This executable is intentionally small. Repo behavior lives in `.ai/sync.py`;
this wrapper handles installation/init ergonomics and then delegates.
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request


KIT_DIR = os.path.dirname(os.path.realpath(__file__))
if os.environ.get("AGENTIC_CONFIG_KIT_DIR"):
    KIT_DIR = os.path.abspath(os.environ["AGENTIC_CONFIG_KIT_DIR"])

REPO_SLUG = "Thjodann/agentic-config"
GITHUB_BASE = "https://github.com/%s" % REPO_SLUG
GITHUB_API_BASE = "https://api.github.com/repos/%s" % REPO_SLUG
DEFAULT_RELEASE_API_URL = "%s/releases/latest" % GITHUB_API_BASE
DEFAULT_RELEASE_ARCHIVE_BASE = "%s/archive/refs/tags" % GITHUB_BASE
DEFAULT_RELEASE_HTML_BASE = GITHUB_BASE
DEFAULT_VERSION = "0.1.0"
INSTALL_MARKER = ".agentic-config-kit-install"
UPDATE_CACHE_TTL_SECONDS = 24 * 60 * 60
SEMVER_RE = re.compile(
    r"^v?(\d+)\.(\d+)\.(\d+)(?:-([0-9A-Za-z.-]+))?(?:\+[0-9A-Za-z.-]+)?$")

GENERATED_IGNORE = [
    ".agentic-config/",
    ".claude/",
    ".cursor/",
    ".devin/",
    ".windsurf/",
    ".agents/",
    ".codex/agents/",
    ".continue/",
    "!.codex/",
    "!.codex/config.toml",
    "!.codex/rules/",
    "!.codex/rules/**",
]

LOCAL_EXCLUDE = [
    ".agentic-config/",
    ".claude/",
    ".cursor/",
    ".devin/",
    ".windsurf/",
    ".agents/",
    ".codex/agents/",
    ".continue/",
]

PROXY_COMMANDS = {
    "sync", "check", "doctor", "bootstrap", "adopt", "reconcile",
    "demote", "promote", "clean",
}


def eprint(message):
    sys.stderr.write(message + "\n")


def command_name():
    name = os.path.basename(sys.argv[0] or "")
    if name in ("agentic", "agentic-config", "agc"):
        return name
    return "agentic"


def version_file():
    return os.path.join(KIT_DIR, "VERSION")


def current_version():
    try:
        with open(version_file(), encoding="utf-8") as f:
            value = f.read().strip()
        return value or DEFAULT_VERSION
    except OSError:
        return DEFAULT_VERSION


def parse_semver(value):
    match = SEMVER_RE.match(str(value).strip())
    if not match:
        return None
    prerelease = match.group(4)
    return (
        int(match.group(1)),
        int(match.group(2)),
        int(match.group(3)),
        prerelease.split(".") if prerelease else [],
    )


def compare_prerelease(left, right):
    if not left and not right:
        return 0
    if not left:
        return 1
    if not right:
        return -1
    for l_part, r_part in zip(left, right):
        l_num = l_part.isdigit()
        r_num = r_part.isdigit()
        if l_num and r_num:
            l_val = int(l_part)
            r_val = int(r_part)
            if l_val != r_val:
                return 1 if l_val > r_val else -1
            continue
        if l_num != r_num:
            return -1 if l_num else 1
        if l_part != r_part:
            return 1 if l_part > r_part else -1
    if len(left) == len(right):
        return 0
    return 1 if len(left) > len(right) else -1


def compare_semver(left, right):
    left_parsed = parse_semver(left)
    right_parsed = parse_semver(right)
    if not left_parsed or not right_parsed:
        return 0
    for i in range(3):
        if left_parsed[i] != right_parsed[i]:
            return 1 if left_parsed[i] > right_parsed[i] else -1
    return compare_prerelease(left_parsed[3], right_parsed[3])


def is_newer_version(candidate, installed):
    return compare_semver(candidate, installed) > 0


def version_tag(value):
    value = str(value).strip()
    if value.startswith("v"):
        return value
    return "v%s" % value


def install_marker_path():
    return os.path.join(KIT_DIR, INSTALL_MARKER)


def read_install_marker():
    data = {}
    try:
        with open(install_marker_path(), encoding="utf-8") as f:
            for raw_line in f:
                line = raw_line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                data[key.strip()] = value.strip()
    except OSError:
        pass
    return data


def install_marker_value(key):
    return read_install_marker().get(key)


def release_api_url():
    return (
        os.environ.get("AGENTIC_CONFIG_RELEASE_API_URL")
        or install_marker_value("release_api_url")
        or DEFAULT_RELEASE_API_URL)


def release_archive_base():
    return (
        os.environ.get("AGENTIC_CONFIG_RELEASE_ARCHIVE_BASE")
        or install_marker_value("release_archive_base")
        or DEFAULT_RELEASE_ARCHIVE_BASE)


def release_html_base():
    return (
        os.environ.get("AGENTIC_CONFIG_RELEASE_HTML_BASE")
        or install_marker_value("release_html_base")
        or DEFAULT_RELEASE_HTML_BASE)


def release_archive_url(tag):
    return "%s/%s.tar.gz" % (release_archive_base().rstrip("/"), version_tag(tag))


def release_html_url(tag):
    return "%s/releases/tag/%s" % (release_html_base().rstrip("/"), version_tag(tag))


def open_url(url, timeout=10):
    if url.startswith("file://"):
        return urllib.request.urlopen(url, timeout=timeout)
    req = urllib.request.Request(
        url,
        headers={
            "Accept": "application/vnd.github+json",
            "User-Agent": "agentic-config/%s" % current_version(),
        },
    )
    return urllib.request.urlopen(req, timeout=timeout)


def fetch_json(url, timeout=10):
    with open_url(url, timeout=timeout) as response:
        return json.loads(response.read().decode("utf-8"))


def select_release(payload):
    if isinstance(payload, list):
        for item in payload:
            if item.get("draft") or item.get("prerelease"):
                continue
            if item.get("tag_name"):
                return item
        return None
    if isinstance(payload, dict) and payload.get("tag_name"):
        if payload.get("draft") or payload.get("prerelease"):
            return None
        return payload
    return None


def latest_release(timeout=10):
    payload = fetch_json(release_api_url(), timeout=timeout)
    release = select_release(payload)
    if not release:
        raise RuntimeError("no stable Agentic Config release found")
    tag = release["tag_name"]
    return {
        "tag": tag,
        "version": tag[1:] if tag.startswith("v") else tag,
        "url": release.get("html_url") or release_html_url(tag),
        "archive_url": release_archive_url(tag),
    }


def update_cache_dir():
    if os.environ.get("AGENTIC_CONFIG_CACHE_DIR"):
        return os.environ["AGENTIC_CONFIG_CACHE_DIR"]
    if os.environ.get("XDG_CACHE_HOME"):
        return os.path.join(os.environ["XDG_CACHE_HOME"], "agentic-config")
    return os.path.join(os.path.expanduser("~"), ".cache", "agentic-config")


def update_cache_path():
    return os.path.join(update_cache_dir(), "update-check.json")


def read_update_cache():
    try:
        with open(update_cache_path(), encoding="utf-8") as f:
            return json.load(f)
    except (OSError, ValueError):
        return None


def write_update_cache(release):
    data = {
        "checked_at": int(time.time()),
        "latest": release.get("version") or release.get("tag"),
        "tag": release.get("tag"),
        "url": release.get("url"),
    }
    try:
        cache_dir = update_cache_dir()
        if not os.path.isdir(cache_dir):
            os.makedirs(cache_dir)
        with open(update_cache_path(), "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2, sort_keys=True)
            f.write("\n")
    except OSError:
        pass


def cache_is_fresh(cache):
    try:
        checked_at = int(cache.get("checked_at", 0))
    except (AttributeError, TypeError, ValueError):
        return False
    return (time.time() - checked_at) < UPDATE_CACHE_TTL_SECONDS


def cached_release(cache):
    if not cache:
        return None
    latest = cache.get("latest") or cache.get("tag")
    tag = cache.get("tag") or version_tag(latest)
    return {
        "tag": tag,
        "version": latest[1:] if isinstance(latest, str) and latest.startswith("v") else latest,
        "url": cache.get("url") or release_html_url(tag),
        "archive_url": release_archive_url(tag),
    }


def print_update_notice(release, command):
    latest = release.get("version") or release.get("tag")
    current = current_version()
    eprint("")
    eprint("Agentic Config update available: %s -> %s" % (current, latest))
    eprint("Run: %s update" % command)
    if release.get("url"):
        eprint("Release: %s" % release["url"])


def auto_update_check(command):
    if os.environ.get("AGENTIC_CONFIG_NO_UPDATE_CHECK"):
        return
    force = os.environ.get("AGENTIC_CONFIG_UPDATE_CHECK_ALWAYS") == "1"
    if not force and not sys.stderr.isatty():
        return

    cache = read_update_cache()
    release = cached_release(cache) if cache_is_fresh(cache) else None
    if not release:
        try:
            release = latest_release(timeout=3)
            write_update_cache(release)
        except Exception:
            return
    if release and is_newer_version(release.get("version"), current_version()):
        print_update_notice(release, command)


def ensure_kit():
    required = [
        os.path.join(KIT_DIR, ".ai", "sync.py"),
        os.path.join(KIT_DIR, "sync-agentic.sh"),
    ]
    missing = [p for p in required if not os.path.exists(p)]
    if missing:
        eprint("ERROR: %s cannot find its bundled files." % command_name())
        for p in missing:
            eprint("  missing %s" % p)
        eprint("Set AGENTIC_CONFIG_KIT_DIR to a full Agentic Config checkout.")
        return False
    return True


def git_output(args, cwd):
    return subprocess.check_output(
        ["git"] + args, cwd=cwd, stderr=subprocess.DEVNULL).decode("utf-8").strip()


def git_root(path):
    try:
        return os.path.abspath(git_output(["rev-parse", "--show-toplevel"], path))
    except Exception:
        return None


def git_dir(path):
    out = git_output(["rev-parse", "--git-dir"], path)
    if os.path.isabs(out):
        return out
    return os.path.abspath(os.path.join(path, out))


def git_tracked(repo):
    try:
        out = subprocess.check_output(
            ["git", "ls-files", "-z"], cwd=repo, stderr=subprocess.DEVNULL)
    except Exception:
        return set()
    return set(p for p in out.decode("utf-8").split("\0") if p)


def copy_tree(src, dst):
    if os.path.exists(dst):
        raise RuntimeError("%s already exists" % dst)
    shutil.copytree(src, dst, ignore=shutil.ignore_patterns("__pycache__", ".DS_Store"))


def copy_file_if_safe(src, dst):
    if os.path.exists(dst):
        with open(src, "rb") as f:
            src_data = f.read()
        with open(dst, "rb") as f:
            dst_data = f.read()
        if src_data != dst_data:
            raise RuntimeError("%s already exists with different content" % dst)
        return False
    parent = os.path.dirname(dst)
    if parent and not os.path.isdir(parent):
        os.makedirs(parent)
    shutil.copyfile(src, dst)
    return True


def append_block(path, start, end, lines):
    existing = ""
    if os.path.isfile(path):
        with open(path, encoding="utf-8") as f:
            existing = f.read()
    if start in existing:
        return False
    parent = os.path.dirname(path)
    if parent and not os.path.isdir(parent):
        os.makedirs(parent)
    with open(path, "a", encoding="utf-8") as f:
        if existing and not existing.endswith("\n"):
            f.write("\n")
        if existing:
            f.write("\n")
        f.write(start + "\n")
        for line in lines:
            f.write(line + "\n")
        f.write(end + "\n")
    return True


def run_sync(repo, ai_dir, args, stealth=False):
    env = dict(os.environ)
    env["AGENTIC_CONFIG_REPO_ROOT"] = repo
    env["AGENTIC_CONFIG_AI_DIR"] = ai_dir
    env["AGENTIC_CONFIG_COMMAND"] = command_name()
    if stealth:
        env["AGENTIC_CONFIG_STEALTH"] = "1"
    else:
        env.pop("AGENTIC_CONFIG_STEALTH", None)
    runner = os.path.join(KIT_DIR, ".ai", "sync.py")
    if not os.path.isfile(runner):
        runner = os.path.join(ai_dir, "sync.py")
    return subprocess.call(
        [sys.executable, runner] + list(args),
        cwd=repo, env=env)


def install_hook(repo):
    root = git_root(repo)
    if not root:
        print("No Git repo detected; skipped pre-commit hook.")
        return
    hook_src = os.path.join(KIT_DIR, "hooks", "pre-commit")
    hook_dst = os.path.join(git_dir(root), "hooks", "pre-commit")
    if os.path.exists(hook_dst):
        print("Pre-commit hook already exists; left it unchanged:")
        print("  %s" % hook_dst)
        return
    copy_file_if_safe(hook_src, hook_dst)
    os.chmod(hook_dst, 0o755)
    print("Installed pre-commit hook: %s" % hook_dst)


def command_init(argv):
    parser = argparse.ArgumentParser(
        prog="%s init" % command_name(),
        description="Initialize Agentic Config in a repository.")
    parser.add_argument("path", nargs="?", default=".")
    parser.add_argument("--stealth", action="store_true",
                        help="Create local ignored projections without tracked Git changes.")
    parser.add_argument("--install-hook", action="store_true",
                        help="Install the optional pre-commit guard when possible.")
    args = parser.parse_args(argv)

    if not ensure_kit():
        return 1
    target = os.path.abspath(args.path)
    if not os.path.isdir(target):
        eprint("ERROR: target does not exist or is not a directory: %s" % target)
        return 1
    if args.stealth:
        return init_stealth(target)
    return init_normal(target, install_precommit=args.install_hook)


def init_normal(target, install_precommit=False):
    ai_dst = os.path.join(target, ".ai")
    if os.path.exists(ai_dst):
        eprint("ERROR: %s already exists. Use %s sync/check/doctor there." %
               (ai_dst, command_name()))
        return 1

    try:
        copy_tree(os.path.join(KIT_DIR, ".ai"), ai_dst)
        copied_wrapper = copy_file_if_safe(
            os.path.join(KIT_DIR, "sync-agentic.sh"),
            os.path.join(target, "sync-agentic.sh"))
        os.chmod(os.path.join(target, "sync-agentic.sh"), 0o755)
        append_block(
            os.path.join(target, ".gitignore"),
            "# BEGIN agentic-config-kit generated projections",
            "# END agentic-config-kit generated projections",
            GENERATED_IGNORE)
    except Exception as e:
        eprint("ERROR: %s" % e)
        return 1

    print("Installed canonical config in %s/.ai" % target)
    if copied_wrapper:
        print("Installed compatibility wrapper: %s/sync-agentic.sh" % target)
    print("Added source-only ignore rules to %s/.gitignore" % target)

    rc = run_sync(target, ai_dst, ["sync"], stealth=False)
    if rc:
        print("")
        print("Initial sync stopped before overwriting existing native IDE config.")
        print("Run: %s doctor" % command_name())
        return rc
    if install_precommit:
        install_hook(target)
    print("")
    print("Ready. Edit .ai/ or ask your IDE for /agentic-config.")
    print("Verify with: %s check" % command_name())
    return 0


def init_stealth(target):
    root = git_root(target)
    if not root:
        eprint("ERROR: %s init --stealth requires a Git repository." % command_name())
        eprint("Stealth mode uses .git/info/exclude so it can avoid tracked repo changes.")
        return 1

    local_ai = os.path.join(root, ".agentic-config", ".ai")
    if not os.path.exists(local_ai):
        try:
            parent = os.path.dirname(local_ai)
            if not os.path.isdir(parent):
                os.makedirs(parent)
            copy_tree(os.path.join(KIT_DIR, ".ai"), local_ai)
            print("Created local canonical config: %s" % local_ai)
        except Exception as e:
            eprint("ERROR: %s" % e)
            return 1
    elif not os.path.isfile(os.path.join(local_ai, "sync.py")):
        eprint("ERROR: %s exists but does not contain sync.py" % local_ai)
        return 1
    else:
        print("Using existing local canonical config: %s" % local_ai)

    tracked = git_tracked(root)
    exclude_lines = list(LOCAL_EXCLUDE)
    if "AGENTS.md" not in tracked:
        exclude_lines.append("AGENTS.md")
    else:
        print("AGENTS.md is tracked; stealth mode will skip Codex managed AGENTS.md updates.")

    try:
        append_block(
            os.path.join(git_dir(root), "info", "exclude"),
            "# BEGIN agentic-config-kit stealth local files",
            "# END agentic-config-kit stealth local files",
            exclude_lines)
    except Exception as e:
        eprint("ERROR: could not update .git/info/exclude: %s" % e)
        return 1
    print("Added local-only excludes to .git/info/exclude")

    rc = run_sync(root, local_ai, ["sync"], stealth=True)
    if rc:
        print("")
        print("Stealth init stopped before writing unsafe output.")
        print("Run: %s doctor" % command_name())
        return rc
    print("")
    print("Stealth setup complete. Local IDE projections are ignored by Git.")
    print("Canonical local source: .agentic-config/.ai/")
    return 0


def discover_config(start):
    cur = os.path.abspath(start)
    while True:
        normal = os.path.join(cur, ".ai", "sync.py")
        stealth = os.path.join(cur, ".agentic-config", ".ai", "sync.py")
        if os.path.isfile(normal):
            return cur, os.path.join(cur, ".ai"), False
        if os.path.isfile(stealth):
            return cur, os.path.join(cur, ".agentic-config", ".ai"), True
        parent = os.path.dirname(cur)
        if parent == cur:
            break
        cur = parent

    root = git_root(start)
    if root:
        normal = os.path.join(root, ".ai", "sync.py")
        stealth = os.path.join(root, ".agentic-config", ".ai", "sync.py")
        if os.path.isfile(normal):
            return root, os.path.join(root, ".ai"), False
        if os.path.isfile(stealth):
            return root, os.path.join(root, ".agentic-config", ".ai"), True
    return None, None, False


def proxy(cmd, rest):
    repo, ai_dir, stealth = discover_config(os.getcwd())
    if not repo:
        eprint("ERROR: no Agentic Config source found.")
        eprint("Run `%s init` or `%s init --stealth` first." %
               (command_name(), command_name()))
        return 1
    return run_sync(repo, ai_dir, [cmd] + rest, stealth=stealth)


def install_update(archive_url):
    installer = os.path.join(KIT_DIR, "install-agentic-config.sh")
    if not os.path.isfile(installer):
        eprint("ERROR: cannot find installer: %s" % installer)
        return 1
    env = dict(os.environ)
    env["AGENTIC_CONFIG_ARCHIVE_URL"] = archive_url
    env["AGENTIC_CONFIG_RELEASE_API_URL"] = release_api_url()
    env["AGENTIC_CONFIG_RELEASE_ARCHIVE_BASE"] = release_archive_base()
    env["AGENTIC_CONFIG_RELEASE_HTML_BASE"] = release_html_base()
    env.pop("AGENTIC_CONFIG_SOURCE_DIR", None)
    return subprocess.call(["sh", installer], env=env)


def platform_default_install_dir():
    return os.path.abspath(os.path.expanduser("~/.local/share/agentic-config-kit"))


def default_install_dir():
    return os.path.abspath(os.path.expanduser(os.environ.get(
        "AGENTIC_CONFIG_HOME", platform_default_install_dir())))


def default_bin_dir():
    return os.path.abspath(os.path.expanduser(os.environ.get(
        "AGENTIC_CONFIG_BIN", "~/.local/bin")))


def readlink_abs(path):
    target = os.readlink(path)
    if not os.path.isabs(target):
        target = os.path.join(os.path.dirname(path), target)
    return os.path.abspath(target)


def files_equal(left, right):
    try:
        with open(left, "rb") as f:
            left_data = f.read()
        with open(right, "rb") as f:
            right_data = f.read()
        return left_data == right_data
    except OSError:
        return False


def managed_cli_entry(path, install_dir):
    target = os.path.join(install_dir, "agentic-config")
    if not os.path.exists(path) and not os.path.islink(path):
        return False
    if os.path.islink(path):
        return readlink_abs(path) == os.path.abspath(target)
    if os.path.isfile(path) and os.path.isfile(target):
        return files_equal(path, target)
    return False


def install_dir_looks_managed(path):
    if not os.path.isdir(path) or os.path.islink(path):
        return False
    marker = os.path.join(path, INSTALL_MARKER)
    legacy_default = os.path.abspath(path) == platform_default_install_dir()
    if not os.path.isfile(marker) and not legacy_default:
        return False
    required = [
        os.path.join(path, "agentic-config"),
        os.path.join(path, ".ai", "sync.py"),
    ]
    return all(os.path.isfile(p) for p in required)


def uninstall_action(path, dry_run, description, directory=False):
    prefix = "Would remove" if dry_run else "Removed"
    print("%s %s: %s" % (prefix, description, path))
    if dry_run:
        return
    if directory:
        shutil.rmtree(path)
    else:
        os.remove(path)


def command_uninstall(argv, command):
    parser = argparse.ArgumentParser(
        prog="%s uninstall" % command,
        description="Remove the user-level Agentic Config CLI install.")
    parser.add_argument("--dry-run", action="store_true",
                        help="Print what would be removed without deleting anything.")
    args = parser.parse_args(argv)

    install_dir = default_install_dir()
    bin_dir = default_bin_dir()
    had_error = False

    print("Agentic Config uninstall")
    print("  kit: %s" % install_dir)
    print("  bin: %s" % bin_dir)

    for name in ["agentic", "agentic-config", "agc"]:
        path = os.path.join(bin_dir, name)
        if not os.path.exists(path) and not os.path.islink(path):
            print("Skipped missing command: %s" % path)
            continue
        if managed_cli_entry(path, install_dir):
            uninstall_action(path, args.dry_run, "command")
        else:
            print("Skipped non-Agentic Config command: %s" % path)

    if os.path.exists(install_dir):
        if install_dir_looks_managed(install_dir):
            uninstall_action(install_dir, args.dry_run, "kit directory", directory=True)
        else:
            eprint("ERROR: refusing to remove install dir that does not look Agentic Config-managed: %s" %
                   install_dir)
            had_error = True
    else:
        print("Skipped missing kit directory: %s" % install_dir)

    if args.dry_run:
        print("Dry run complete; no files were removed.")
    elif not had_error:
        print("Uninstall complete.")
        print("Open a new shell or run `hash -r` / `rehash` if your shell cached the command.")
    return 1 if had_error else 0


def command_update(argv, command):
    parser = argparse.ArgumentParser(
        prog="%s update" % command,
        description="Check for or install Agentic Config updates.")
    parser.add_argument("--check", action="store_true",
                        help="Check for an update without installing it.")
    parser.add_argument("--force", action="store_true",
                        help="Install the selected release even if it is not newer.")
    parser.add_argument("--version", dest="target_version",
                        help="Install a specific release tag such as v0.1.0.")
    args = parser.parse_args(argv)

    current = current_version()
    try:
        if args.target_version:
            tag = version_tag(args.target_version)
            release = {
                "tag": tag,
                "version": tag[1:] if tag.startswith("v") else tag,
                "url": release_html_url(tag),
                "archive_url": release_archive_url(tag),
            }
        else:
            release = latest_release(timeout=15)
    except Exception as e:
        eprint("ERROR: could not check for Agentic Config updates: %s" % e)
        return 1

    latest = release.get("version") or release.get("tag")
    newer = is_newer_version(latest, current)
    write_update_cache(release)

    if args.check:
        if newer:
            print("Update available: %s -> %s" % (current, latest))
            print("Run: %s update" % command)
            if release.get("url"):
                print("Release: %s" % release["url"])
        else:
            print("Agentic Config is up to date (%s)." % current)
        return 0

    explicit_version = bool(args.target_version)
    if not newer and not args.force and not explicit_version:
        print("Agentic Config is up to date (%s)." % current)
        return 0

    archive_url = os.environ.get("AGENTIC_CONFIG_ARCHIVE_URL") or release["archive_url"]
    print("Updating Agentic Config: %s -> %s" % (current, latest))
    if release.get("url"):
        print("Release: %s" % release["url"])
    return install_update(archive_url)


def print_help():
    cmd = command_name()
    print("""Agentic Config

Usage:
  {cmd} init [--stealth] [--install-hook] [path]
  {cmd} sync
  {cmd} check
  {cmd} doctor [--staged]
  {cmd} bootstrap
  {cmd} adopt <ide> <path>
  {cmd} adopt --all
  {cmd} reconcile <kind> <name>
  {cmd} reconcile --all-exact
  {cmd} demote <consumer-ide> <generated-path>
  {cmd} promote <consumer-ide> <generated-path>
  {cmd} clean [--native-duplicates]
  {cmd} update [--check] [--force] [--version <tag>]
  {cmd} uninstall [--dry-run]
  {cmd} version

Normal init creates repo-local `.ai/` source and source-only ignore rules.
Stealth init creates local ignored `.agentic-config/.ai/` source with no tracked Git changes.
`agentic` is the primary CLI. `agentic-config` is a compatibility command;
`agc` is a legacy alias when available.
""".format(cmd=cmd).rstrip())


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    cmd_name = command_name()
    if not argv or argv[0] in ("-h", "--help", "help"):
        print_help()
        return 0
    cmd = argv[0]
    if cmd in ("-V", "--version", "version"):
        print("%s %s" % (cmd_name, current_version()))
        return 0
    if cmd == "init":
        rc = command_init(argv[1:])
    elif cmd == "update":
        return command_update(argv[1:], cmd_name)
    elif cmd == "uninstall":
        return command_uninstall(argv[1:], cmd_name)
    elif cmd in PROXY_COMMANDS:
        rc = proxy(cmd, argv[1:])
    else:
        eprint("ERROR: unknown command: %s" % cmd)
        eprint("Run `%s --help`." % cmd_name)
        return 1
    auto_update_check(cmd_name)
    return rc


if __name__ == "__main__":
    sys.exit(main())
